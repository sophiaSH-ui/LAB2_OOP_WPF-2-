<Window x:Class="lab2_wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calculator" Height="650" Width="400" x:Name="CalcWindow"
        PreviewKeyDown="Window_PreviewKeyDown" Focusable="True" WindowStartupLocation="CenterScreen"
        Background="#0F0F12">

    <Window.Resources>

        <Style TargetType="Button">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Foreground" Value="#E1BEE7"/>
            <Setter Property="Background" Value="#1E1E26"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#311B92"/>
                                <Setter Property="Foreground" Value="#FF80AB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#AD1457"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="IconButtonStyle" TargetType="ButtonBase">
            <Setter Property="Background" Value="#2D2D3A"/>
            <Setter Property="Foreground" Value="#FF80AB"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ButtonBase">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10">

                            <TextElement.Foreground>
                                <Binding Path="Foreground" RelativeSource="{RelativeSource TemplatedParent}"/>
                            </TextElement.Foreground>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4A148C"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="140"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <Grid Grid.Row="0">
            <ToggleButton x:Name="MenuToggle" Content="☰" Width="50" Height="50" 
              HorizontalAlignment="Left" Style="{StaticResource IconButtonStyle}"
              Checked="MenuToggle_Checked" Unchecked="MenuToggle_Unchecked"
              RenderTransformOrigin="0.5,0.5">
                <ToggleButton.RenderTransform>
                    <RotateTransform x:Name="MenuRotate" Angle="0"/>
                </ToggleButton.RenderTransform>
            </ToggleButton>

            <Button Content="⌫" Width="50" Height="50" 
                    HorizontalAlignment="Right" 
                    Style="{StaticResource IconButtonStyle}"
                    Click="Backspace_Click"/>
        </Grid>

        <Border Grid.Row="1" CornerRadius="15" Margin="0,15">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#2E1A47" Offset="0"/>
                    <GradientStop Color="#161625" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel VerticalAlignment="Bottom" Margin="15">
                <TextBlock x:Name="HistoryDisplay" 
               Text="" 
               Foreground="#FF80AB" 
               FontSize="18" 
               FontWeight="SemiBold"
               TextAlignment="Right" 
               Margin="0,0,5,-2"/>

                <TextBox x:Name="Display" 
             Text="0" 
             TextAlignment="Right" 
             FontSize="46" 
             Foreground="White" 
             BorderThickness="0" 
             Background="Transparent" 
             IsReadOnly="True" 
             Margin="0,0,5,-2"
             Padding="0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>

            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>


            <Button Content="CE" Grid.Row="0" Grid.Column="0" Click="Undo_Click" Foreground="#FF5252" Background="#2D1B1B"/>
            <Button Content="C"  Grid.Row="0" Grid.Column="1" Click="Clear_Click" Background="#252530"/>
            <Button Content="R" Grid.Row="0" Grid.Column="2" Click="Redo_Click" Foreground="#448AFF" Background="#1B212D"/>
            <Button Content="÷"  Grid.Row="0" Grid.Column="3" Click="Op_Click" Background="#2A1E35" Foreground="#BA68C8"/>

            <Button Content="7" Grid.Row="1" Grid.Column="0" Click="Digit_Click"/>
            <Button Content="8" Grid.Row="1" Grid.Column="1" Click="Digit_Click"/>
            <Button Content="9" Grid.Row="1" Grid.Column="2" Click="Digit_Click"/>
            <Button Content="×" Grid.Row="1" Grid.Column="3" Click="Op_Click" Background="#2A1E35" Foreground="#BA68C8"/>

            <Button Content="4" Grid.Row="2" Grid.Column="0" Click="Digit_Click"/>
            <Button Content="5" Grid.Row="2" Grid.Column="1" Click="Digit_Click"/>
            <Button Content="6" Grid.Row="2" Grid.Column="2" Click="Digit_Click"/>
            <Button Content="-" Grid.Row="2" Grid.Column="3" Click="Op_Click" Background="#2A1E35" Foreground="#BA68C8"/>

            <Button Content="1" Grid.Row="3" Grid.Column="0" Click="Digit_Click"/>
            <Button Content="2" Grid.Row="3" Grid.Column="1" Click="Digit_Click"/>
            <Button Content="3" Grid.Row="3" Grid.Column="2" Click="Digit_Click"/>
            <Button Content="+" Grid.Row="3" Grid.Column="3" Click="Op_Click" Background="#2A1E35" Foreground="#BA68C8"/>

            <Button Content="00" Grid.Row="4" Grid.Column="0" Click="Digit_Click"/>
            <Button Content="0"  Grid.Row="4" Grid.Column="1" Click="Digit_Click"/>
            <Button Content=","  Grid.Row="4" Grid.Column="2" Click="Digit_Click"/>
            <Button Content="="  Grid.Row="4" Grid.Column="3" Click="Equal_Click" 
                    Background="#880E4F" Foreground="White" FontWeight="Bold"/>

            <Border x:Name="ScientificPanel" Grid.Column="4" Grid.RowSpan="5" 
            Width="0" Opacity="0" ClipToBounds="True" Margin="2,0,0,0">
                <Grid Width="80">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button Content="π" Grid.Row="0" Click="Scientific_Click" Background="#1A237E" Foreground="#9FA8DA"/>
                    <Button Content="e" Grid.Row="1" Click="Scientific_Click" Background="#1A237E" Foreground="#9FA8DA"/>
                    <Button Content="√" Grid.Row="2" Click="Scientific_Click" Background="#1A237E" Foreground="#9FA8DA"/>
                    <Button Content="ln" Grid.Row="3" Click="Scientific_Click" Background="#1A237E" Foreground="#9FA8DA"/>
                    <Button Content="^" Grid.Row="4" Click="Scientific_Click" Background="#1A237E" Foreground="#9FA8DA"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>